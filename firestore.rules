rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Data Model
    // ===============================================================
    //
    // Collection: players/{userId}
    // Fields: uid, email, displayName, photoURL, provider, totalRuns,
    //         totalScore, totalKills, highScore, maxWave, totalPlayTime,
    //         averageScore, favoriteClass, lastPlayTime, achievements,
    //         createdAt, updatedAt
    //
    // Subcollection: players/{userId}/runs/{runId}
    // Fields: score, wave, heroClass, kills, damageDealt, damageTaken,
    //         comboMultiplier, abilitiesUsed, upgradesApplied, duration,
    //         startTime, endTime, timestamp
    //
    // Collection: meta/global_stats
    // Fields: totalPlayers, totalRuns, totalScore, highScore, maxWave,
    //         lastUpdated
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ===============================================================
    // Player Stats Rules
    // ===============================================================
    match /players/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && 
                       request.resource.data.uid == request.auth.uid &&
                       request.resource.data.email == request.auth.email;
      allow update: if isOwner(userId) &&
                       request.resource.data.uid == resource.data.uid;
      
      // Game Runs Subcollection
      match /runs/{runId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) &&
                         request.resource.data.userId == request.auth.uid;
      }
    }

    // ===============================================================
    // Global Stats Rules (Read-only for players)
    // ===============================================================
    match /meta/global_stats {
      allow read: if isAuthenticated();
      allow write: if false; // Only server-side updates
    }

    // ===============================================================
    // Default Deny
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
